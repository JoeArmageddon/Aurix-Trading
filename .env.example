# =============================================================================
# Aurix Trading Platform - Environment Variables
# =============================================================================
# This is the root environment file template
# For specific configurations, see:
#   - Frontend: apps/web/.env.local.example
#   - Backend: apps/server/.env.example
# =============================================================================

# -----------------------------------------------------------------------------
# Quick Start - Minimum Required Variables
# Copy the appropriate files and fill in these values to get started
# -----------------------------------------------------------------------------

# === FRONTEND (apps/web/.env.local) ===
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_API_URL=http://localhost:3001

# === BACKEND (apps/server/.env) ===
PORT=3001
JWT_SECRET=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
GEMINI_API_KEY=

# === OPTIONAL BUT RECOMMENDED ===
RESEND_API_KEY=
GROQ_API_KEY=
WHALE_ALERT_API_KEY=

# =============================================================================
# Full Configuration Guide
# =============================================================================
#
# 1. Firebase Setup:
#    - Create project at https://console.firebase.google.com
#    - Enable Authentication (Email/Password)
#    - Create Firestore database
#    - Get config for frontend (NEXT_PUBLIC_*)
#    - Generate service account key for backend (FIREBASE_*)
#
# 2. Upstash Redis:
#    - Create database at https://console.upstash.com
#    - Copy REST URL and Token
#
# 3. AI APIs:
#    - Gemini: https://makersuite.google.com/app/apikey
#    - Groq: https://console.groq.com/keys (fallback)
#
# 4. Email (Resend):
#    - Sign up at https://resend.com
#    - Verify domain and generate API key
#
# 5. Whale Alerts (Optional):
#    - Get API key at https://whale-alert.io/account/api
#
# =============================================================================
