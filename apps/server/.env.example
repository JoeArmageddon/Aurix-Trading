# =============================================================================
# Aurix Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials to git
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
# JWT_SECRET should be a strong random string (32+ characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# -----------------------------------------------------------------------------
# Binance WebSocket Configuration
# -----------------------------------------------------------------------------
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# -----------------------------------------------------------------------------
# AI API Keys
# Get from Google AI Studio: https://makersuite.google.com/app/apikey
# Get from Groq Console: https://console.groq.com/keys
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# Upstash Redis Configuration
# Get from Upstash Console: https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_TOKEN=your_redis_token_here

# -----------------------------------------------------------------------------
# Firebase Admin SDK Configuration
# Get from Firebase Console: https://console.firebase.google.com
# Project Settings > Service Accounts > Generate New Private Key
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Copy the entire private key including BEGIN/END lines, replace newlines with \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE_WITH_NEWLINES_AS_\n\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Resend Email Configuration
# Get from Resend Dashboard: https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The email address verified in Resend for sending
RESEND_FROM_EMAIL=alerts@yourdomain.com

# -----------------------------------------------------------------------------
# Optional: External API Keys
# These services have free tiers and enhance functionality
# -----------------------------------------------------------------------------

# Whale Alert API for on-chain monitoring
# Get from: https://whale-alert.io/account/api
WHALE_ALERT_API_KEY=your_whale_alert_api_key_here

# Reddit API (for enhanced sentiment analysis)
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AurixTrading/1.0 (by /u/yourusername)

# Yahoo Finance API Key (optional - works without key for delayed data)
YAHOO_API_KEY=

# Fear & Greed API (alternative.me - free, no key required)
FEAR_GREED_API=https://api.alternative.me/fng/

# -----------------------------------------------------------------------------
# Feature Flags (optional)
# -----------------------------------------------------------------------------
# ENABLE_WHALE_ALERTS=true
# ENABLE_SENTIMENT_ANALYSIS=true
# ENABLE_AI_REPORTS=true
# LOG_LEVEL=info
